# Clé secrète JWT — changez cette valeur en production !
JWT_SECRET="changez-moi-en-production"

# Port du serveur (défaut: 3001 en local, configuré par l'hôte en ligne)
PORT=3001

# URL de l'application en production (pour CORS)
APP_URL="https://votre-app.onrender.com"

# Gemini API (optionnel — si vous utilisez des fonctionnalités IA)
GEMINI_API_KEY=""
